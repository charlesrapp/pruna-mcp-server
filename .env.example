# Pruna MCP Server environment variables
# Copy to .env and fill in your values

# Required: Your Pruna AI API key (https://pruna.ai)
PRUNA_API_KEY=

# Optional: Directory for downloaded generated files
# PRUNA_OUTPUT_DIR=./pruna-output

# Optional: Seconds between async status polls
# PRUNA_POLL_INTERVAL=2

# Optional: HTTP timeout in seconds
# PRUNA_TIMEOUT=120

# Optional: Max retries on transient errors (429, 502-504)
# PRUNA_MAX_RETRIES=3
